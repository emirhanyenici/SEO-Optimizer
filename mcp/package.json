{
  "name": "seo-optimizer-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server exposing the SEO Optimizer's specialist agents (as prompts) and crawl tools (fetch_page, pagespeed, serp). Inference runs on the connecting client's own Claude — no API key, no central billing.",
  "keywords": ["mcp", "modelcontextprotocol", "seo", "claude"],
  "license": "MIT",
  "author": "emirhanyenici",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emirhanyenici/SEO-Optimizer-MCP.git"
  },
  "homepage": "https://github.com/emirhanyenici/SEO-Optimizer-MCP#readme",
  "bugs": "https://github.com/emirhanyenici/SEO-Optimizer-MCP/issues",
  "type-note": "Self-contained: dist/index.js inlines the reused prompts/helpers; only the 3 deps below are external.",
  "bin": {
    "seo-optimizer-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --packages=external --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\"",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.0.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.0"
  }
}
