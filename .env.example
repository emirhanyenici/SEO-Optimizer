# SEO Optimizer — environment değişkenleri şablonu
# Bu dosyayı .env.local olarak kopyala ve GERÇEK değerleri gir.
# .env.local asla commit edilmez (.gitignore kapsıyor).
#
#   cp .env.example .env.local && nano .env.local && chmod 600 .env.local

# --- ZORUNLU ---
# Anthropic API anahtarı. console.anthropic.com'dan alınır.
# Claude Pro/Max ÜYELİĞİNDEN AYRIDIR ve token başına faturalanır.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OPSİYONEL (varsayılanları vardır) ---
# Tüm analiz çağrılarında kullanılan model. Maliyet için Haiku önerilir.
ANTHROPIC_MODEL=claude-haiku-4-5
# Yanıt başına maksimum token (varsayılan: 16384)
# ANTHROPIC_MAX_TOKENS=16384

# Google PageSpeed Insights API anahtarı (page-speed agent için).
# Yoksa PageSpeed metrikleri atlanır.
GOOGLE_PAGESPEED_API_KEY=

# SerpAPI anahtarı (SERP/rakip verisi için). Yoksa ilgili özellikler kısıtlanır.
SerpAPI_KEY=
